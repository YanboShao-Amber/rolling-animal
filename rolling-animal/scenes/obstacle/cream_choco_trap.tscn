[sub_resource type="Shader" id="Shader_white_outline"]
code = "shader_type canvas_item;\n\nuniform float outline_size : hint_range(1.0, 4.0, 0.5) = 2.0;\n\nvoid fragment() {\n\tfloat center_alpha = texture(TEXTURE, UV).a;\n\tvec2 step_size = TEXTURE_PIXEL_SIZE * outline_size;\n\tfloat neighbor_alpha = 0.0;\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV + vec2(step_size.x, 0.0)).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV - vec2(step_size.x, 0.0)).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV + vec2(0.0, step_size.y)).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV - vec2(0.0, step_size.y)).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV + step_size).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV - step_size).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV + vec2(step_size.x, -step_size.y)).a);\n\tneighbor_alpha = max(neighbor_alpha, texture(TEXTURE, UV + vec2(-step_size.x, step_size.y)).a);\n\tfloat outline_alpha = max(neighbor_alpha - center_alpha, 0.0);\n\tCOLOR = vec4(1.0, 1.0, 1.0, outline_alpha);\n}\n"

