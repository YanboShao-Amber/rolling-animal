[node name="Instructions" type="Label" parent="UILayer" unique_id=1418663214]
offset_left = 40.0
offset_top = 30.0
offset_right = 1820.0
offset_bottom = 230.0
theme_override_font_sizes/font_size = 28
text = "§1 灰盒关 · 自动向右滚，[空格]跳
绿色=毒水，掉进去=死；保持小(别点鼠标)跳得更高更远
挡路的墙：[左键]狂点变大撞碎 → 再松手缩小才跳得过后面的沟
风口：保持小才被吹上去 → 跳台 → 落地狂点变大踩橙色按钮 → 出气泡过毒池
死了从最近的绿旗检查点复活"

